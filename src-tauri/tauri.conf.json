{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Slovo",
  "version": "0.1.0",
  "identifier": "org.merzlov.slovo",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "width": 440,
        "height": 280,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": true,
        "visible": false,
        "alwaysOnTop": false,
        "center": true,
        "shadow": true,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {},
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
